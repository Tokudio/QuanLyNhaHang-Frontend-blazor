@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!-- === THANH MENU TRÊN CÙNG === -->
        <div class="top-row px-4 navbar navbar-dark bg-dark">
            <div class="container-fluid d-flex justify-content-between align-items-center">
                <a class="navbar-brand" href="">QuanLyNhaHang_DotNet</a>

                <div class="d-flex align-items-center gap-3">
                    @if (isLoggedIn)
                    {
                        <span class="text-light me-3">
                            Xin chào, <strong>@fullName</strong>
                        </span>
                        <button class="btn btn-outline-light btn-sm" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </button>
                    }
                    else
                    {
                        <a href="/login" class="btn btn-outline-light btn-sm">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
        <!-- ============================ -->

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<!-- Mobile Nav -->
<div class="top-row ps-3 navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">QuanLyNhaHang_DotNet</a>
        <button class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        @* Giữ nguyên các link NavMenu của bạn *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="customer-menu">
                <span class="bi bi-list-nested-nav-menu"></span> Khách hàng
            </NavLink>
        </div>
        <!-- Thêm các link khác nếu cần -->
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    // State người dùng
    private bool isLoggedIn = false;
    private string fullName = "Khách";

    protected override async Task OnInitializedAsync()
    {
        await LoadUserInfo();
    }

    private async Task LoadUserInfo()
    {
        try
        {
            var userJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "currentUser");
            if (!string.IsNullOrEmpty(userJson))
            {
                var user = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(userJson);
                fullName = user.GetProperty("fullName").GetString() ?? "Khách";
                isLoggedIn = true;
            }
        }
        catch { }
    }

    private async Task Logout()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "currentUser");
        isLoggedIn = false;
        fullName = "Khách";
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}